        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/deny-netrc-write.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
