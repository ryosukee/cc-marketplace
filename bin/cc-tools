#!/bin/bash
# cc-tools — marketplace CLI
# plugin の API スクリプトを呼び出すフロントエンド
set -euo pipefail

MARKETPLACE_NAME="cc-tools"
INSTALLED_PLUGINS="$HOME/.claude/plugins/installed_plugins.json"

usage() {
  cat <<'USAGE'
Usage: cc-tools <plugin> <command> [args...]
       cc-tools doctor
       cc-tools help

Plugins:
  version-check   バージョン追跡

Commands per plugin:
  version-check:
    get                     現在のバージョンを取得
    check                   更新有無をチェック
    summaries [LIMIT]       保存済み changelog 要約の一覧
    summary <VERSION>       指定バージョンの changelog 要約を表示
USAGE
}

# installed_plugins.json から plugin の installPath を解決
resolve_plugin_path() {
  local plugin_name="$1"
  local key="${plugin_name}@${MARKETPLACE_NAME}"

  if [ ! -f "$INSTALLED_PLUGINS" ]; then
    echo "error: $INSTALLED_PLUGINS not found" >&2
    return 1
  fi

  local path
  path=$(jq -r --arg key "$key" '.plugins[$key][0].installPath // empty' "$INSTALLED_PLUGINS")

  if [ -z "$path" ]; then
    echo "error: plugin '$plugin_name' not found in $MARKETPLACE_NAME" >&2
    return 1
  fi

  if [ ! -d "$path" ]; then
    echo "error: plugin path does not exist: $path" >&2
    return 1
  fi

  echo "$path"
}

# コマンド名から API スクリプトのファイル名を解決
resolve_api_script() {
  local plugin_path="$1"
  local command="$2"
  local plugin_name="$3"

  local script_name=""
  case "${plugin_name}:${command}" in
    version-check:get)       script_name="get-version.sh" ;;
    version-check:check)     script_name="check-update.sh" ;;
    version-check:summaries) script_name="list-changelog-summaries.sh" ;;
    version-check:summary)   script_name="get-changelog-summary.sh" ;;
    *)
      echo "error: unknown command '$command' for plugin '$plugin_name'" >&2
      return 1
      ;;
  esac

  local script_path="$plugin_path/scripts/api/$script_name"

  if [ ! -f "$script_path" ]; then
    echo "error: API script not found: $script_path" >&2
    return 1
  fi

  echo "$script_path"
}

# doctor: ヘルスチェック
cmd_doctor() {
  local ok=true

  echo "cc-tools doctor"
  echo "==============="

  # jq
  if command -v jq &>/dev/null; then
    echo "  [ok] jq"
  else
    echo "  [ng] jq: not found"
    ok=false
  fi

  # installed_plugins.json
  if [ -f "$INSTALLED_PLUGINS" ]; then
    echo "  [ok] installed_plugins.json"
  else
    echo "  [ng] installed_plugins.json: not found"
    ok=false
  fi

  # 各 plugin のパス
  for plugin in version-check; do
    local path
    if path=$(resolve_plugin_path "$plugin" 2>/dev/null); then
      echo "  [ok] $plugin: $path"
    else
      echo "  [ng] $plugin: not installed"
      ok=false
    fi
  done

  echo ""
  if $ok; then
    echo "All checks passed."
  else
    echo "Some checks failed."
    return 1
  fi
}

# メイン
if [ $# -eq 0 ]; then
  usage
  exit 0
fi

case "$1" in
  help|--help|-h)
    usage
    exit 0
    ;;
  doctor)
    cmd_doctor
    exit $?
    ;;
  version-check)
    plugin_name="$1"
    if [ $# -lt 2 ]; then
      echo "error: missing command for plugin '$plugin_name'" >&2
      echo "Run 'cc-tools help' for usage." >&2
      exit 1
    fi
    command="$2"
    shift 2

    plugin_path=$(resolve_plugin_path "$plugin_name")
    script_path=$(resolve_api_script "$plugin_path" "$command" "$plugin_name")

    # CLAUDE_PLUGIN_DATA: {plugin}-{marketplace} で @ を - に置換
    plugin_data_id="${plugin_name}-${MARKETPLACE_NAME}"
    plugin_data_dir="$HOME/.claude/plugins/data/$plugin_data_id"

    export CLAUDE_PLUGIN_ROOT="$plugin_path"
    export CLAUDE_PLUGIN_DATA="$plugin_data_dir"
    exec bash "$script_path" "$@"
    ;;
  *)
    echo "error: unknown plugin or command '$1'" >&2
    echo "Run 'cc-tools help' for usage." >&2
    exit 1
    ;;
esac
